# LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# API Keys (optional - agents degrade gracefully without them)
APOLLO_API_KEY=
HUNTER_API_KEY=
CLEARBIT_API_KEY=

# NYC OpenData
NYC_OPENDATA_APP_TOKEN=

# Database
DATABASE_PATH=salesleads.db

# Scheduling
DAILY_RUN_HOUR=6
MARKETPLACE_INTERVAL_HOURS=4

# Agent Settings
MAX_AGENT_WORKERS=4
AGENT_TIMEOUT_SECONDS=300

# LinkedIn (use with caution)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Dedup
DEDUP_SIMILARITY_THRESHOLD=85

# Dashboard
STREAMLIT_PORT=8501

# FastAPI
FASTAPI_PORT=8000
CORS_ORIGINS=http://localhost:5173
